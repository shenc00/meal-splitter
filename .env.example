# Add your Anthropic API key here for menu photo extraction
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Supabase — required for shared sessions (ordering across devices).
# Create a free project at https://supabase.com, then Project Settings → API.
# These are exposed to the browser (anon key is public by design); never put
# the service_role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
